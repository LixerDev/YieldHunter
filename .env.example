# ================================
# YieldHunter Configuration
# ================================

# Discord Webhook URL (optional — for APY change alerts)
DISCORD_WEBHOOK_URL=

# ================================
# Scan Settings
# ================================

# Refresh interval in seconds for watch mode
REFRESH_INTERVAL=30

# Minimum TVL in USD to include an opportunity (filter out tiny pools)
MIN_TVL_USD=100000

# Minimum APY to include in results (0 = show all)
MIN_APY_PCT=0.0

# Maximum number of results to display
MAX_RESULTS=20

# ================================
# Risk Settings
# ================================

# Maximum risk score to include (0-100, 100 = include all)
MAX_RISK_SCORE=100

# ================================
# Optimizer Settings
# ================================

# Default capital amount for optimization (USD)
DEFAULT_CAPITAL_USD=10000

# Maximum allocation to one protocol (%)
MAX_PER_PROTOCOL_PCT=40

# Maximum allocation to one token (%)
MAX_PER_TOKEN_PCT=60

# Minimum allocation per position (USD)
MIN_POSITION_USD=500

# ================================
# Alert Settings
# ================================

# APY drop threshold to trigger alert (percentage points)
ALERT_APY_DROP_PCT=1.0

# New opportunity APY threshold
ALERT_NEW_OPPORTUNITY_APY=8.0

# Alert cooldown (minutes)
ALERT_COOLDOWN_MINUTES=60

# ================================
# Logging
# ================================
LOG_LEVEL=INFO
